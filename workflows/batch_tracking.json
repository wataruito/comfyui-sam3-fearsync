      "score_threshold": 0.3
    }
  },
  "4": {
    "class_type": "SAM3Propagate",
    "inputs": {
      "sam3_model": [
        "1",
        0
      ],
      "video_state": [
        "3",
        0
      ],
      "start_frame": 0,
      "end_frame": -1,
      "direction": "both"
    }
  },
  "5": {
    "class_type": "SAM3SavePropagation",
    "inputs": {
      "masks": [
        "4",
        0
      ],
      "scores": [
        "4",
        1
      ],
      "video_state": [
        "4",
        2
      ],
      "filename_prefix": "video/example/sam3_propa"
    }
  }
