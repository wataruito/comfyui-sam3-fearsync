{
  "1": {
    "class_type": "LoadSAM3Model",
    "inputs": {
      "precision": "auto",
      "attention": "auto",
      "compile": false
    }
  },
  "2": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "/path/to/video.mp4",
      "force_rate": 0,
      "custom_width": 0,
      "custom_height": 0,
      "frame_load_cap": 0,
      "skip_first_frames": 0,
      "select_every_nth": 1,
      "format": "AnimateDiff"
    }
  },
  "3": {
    "class_type": "SAM3TwoMouseTracking",
    "inputs": {
      "video_frames": [
        "2",
        0
      ],
